# VoltSense CSMS — environment variables

# PostgreSQL connection string (required at startup)
DATABASE_URL=postgres://user:password@localhost:5432/voltsense

# HTTP server
PORT=3000
HOST=0.0.0.0

# Admin/dev Basic Auth shield (required — server refuses to start without both)
VOLTSENSE_SHIELD_USER=admin
VOLTSENSE_SHIELD_PASSWORD=

# OCPP Security Profile 1 — charger WebSocket Basic Auth (OCPPSetTool)
OCPP_AUTH_USER=VS-MAN-001
OCPP_AUTH_PASSWORD=

# Go Hotels host earnings page (public/host-earnings.html → GET /host/earnings)
# Distinct from VOLTSENSE_SHIELD_* — do NOT use these on /admin/*
HOST_AUTH_USER=gohotels
HOST_AUTH_PASSWORD=

# PayMongo payment rail
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_WEBHOOK_SECRET=whsk_...
# Optional overrides (defaults shown)
# PAYMONGO_BASE_URL=https://api.paymongo.com/v1
# PAYMONGO_TIMEOUT_MS=15000
